{
  "commands": [
    {
      "type": "regex",
      "phrases": [
        ".*(list|show|what).*(processes|running|active|apps|open).*"
      ],
      "action": "run_cmd",
      "params": { "command": "tasklist /fi \"status eq running\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(kill|end|stop|terminate|force close) (process|app|program|task )?(.*)"
      ],
      "action": "task_kill",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(process count|how many processes|number of processes).*"
      ],
      "action": "run_cmd",
      "params": { "command": "tasklist | find /c /v \"\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(top|highest|most).*(process|memory|cpu).*",
        ".*(high).*(cpu|memory).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"Get-Process | Sort-Object WorkingSet64 -Descending | Select-Object -First 10 Name, WorkingSet64, CPU | Format-Table -AutoSize\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(services|service).*(status|running|list|windows).*"
      ],
      "action": "run_cmd",
      "params": { "command": "sc query" }
    },
    {
      "type": "prefix",
      "phrases": [
        "start service ", "stop service ",
        "restart service ", "enable service ",
        "disable service "
      ],
      "action": "run_cmd",
      "params": { "command": "sc" }
    }
  ]
}
