{
  "commands": [
    {
      "type": "contains",
      "phrases": [
        "my ip", "ip address", "show my ip",
        "network ip", "local ip", "what is my ip",
        "my public ip", "public ip", "external ip",
        "ipv4 address", "ipv6 address", "tell me my ip",
        "my ip address", "show ip"
      ],
      "action": "get_ip_address",
      "params": {}
    },
    {
      "type": "contains",
      "phrases": [
        "network status", "wifi status", "network info",
        "connection status", "internet status",
        "network connection", "am i connected",
        "internet connection", "wifi signal",
        "network strength", "connection info",
        "network diagnostics"
      ],
      "action": "run_cmd",
      "params": { "command": "ipconfig /all" }
    },
    {
      "type": "contains",
      "phrases": [
        "disk usage", "disk space", "storage",
        "how much space", "drive status", "free space",
        "disk free", "storage space", "remaining storage",
        "disk capacity", "hard drive space",
        "ssd space", "how much storage left",
        "disk utilization"
      ],
      "action": "run_cmd",
      "params": { "command": "wmic logicaldisk get size,freespace,caption" }
    },
    {
      "type": "contains",
      "phrases": [
        "system uptime", "how long has pc been on",
        "uptime", "pc uptime", "how long has my pc been on",
        "system running time", "last boot time",
        "how long since restart", "uptime status",
        "running since"
      ],
      "action": "run_cmd",
      "params": { "command": "systeminfo | find \"System Boot Time\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(test|check).*(internet|connection|speed).*",
        ".*(ping).*(google).*",
        ".*(is internet working).*"
      ],
      "action": "run_cmd",
      "params": { "command": "ping -n 4 8.8.8.8" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what is my|show my|tell me my)?.*(hostname|computer name|device name).*"
      ],
      "action": "run_cmd",
      "params": { "command": "hostname" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what is my|show my|tell me my)?.*(mac address|physical address|network mac).*"
      ],
      "action": "run_cmd",
      "params": { "command": "getmac" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(flush|clear|reset).*(dns|dns cache).*"
      ],
      "action": "run_cmd",
      "params": { "command": "ipconfig /flushdns" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(renew|release|refresh).*(ip|dhcp|ip address).*"
      ],
      "action": "run_cmd",
      "params": { "command": "ipconfig /renew" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(list|available|show|scan).*(wifi|networks|wifi networks).*"
      ],
      "action": "run_cmd",
      "params": { "command": "netsh wlan show networks" }
    },
    {
      "type": "contains",
      "phrases": [
        "active connections", "network connections",
        "open ports", "listening ports",
        "tcp connections", "active ports"
      ],
      "action": "run_cmd",
      "params": { "command": "netstat -an" }
    }
  ]
