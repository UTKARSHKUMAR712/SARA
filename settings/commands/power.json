{
  "commands": [
    {
      "type": "regex",
      "phrases": [
        ".*(lock|secure).*(pc|computer|system|workstation|screen|desktop|windows).*"
      ],
      "action": "lock_pc",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(sleep|suspend|standby|hibernate).*(pc|computer|system|laptop).*",
        ".*(put).*(pc|computer|system).*(sleep|hibernate).*"
      ],
      "action": "run_cmd",
      "params": { "command": "rundll32.exe powrprof.dll,SetSuspendState 0,1,0" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(abort|cancel|stop|dont|nevermind).*(shutdown|restart|power off|reboot).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /a" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(shutdown|turn off|power off|power down|shut down|switch off).*(pc|computer|system|laptop).*(now|immediately|fast|quick).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /s /t 0" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(shutdown|turn off|power off|power down|shut down|switch off).*(pc|computer|system|laptop|it).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /s /t 10" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(restart|reboot).*(pc|computer|system|laptop).*(now|immediately|fast|quick|force).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /r /t 0" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(restart|reboot).*(pc|computer|system|laptop|it).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /r /t 10" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(sign out|log off|log out|sign off|signout|logoff|switch user).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /l" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(safe mode).*(restart|boot).*",
        ".*(restart|boot).*(safe mode).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shutdown /r /o /t 10" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(turn on|enable|start).*(wifi|wi-fi|wireless).*",
        ".*(wifi|wi-fi).*(on).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"(Get-NetAdapter -Name '*Wi-Fi*','*Wireless*').Name | ForEach-Object { Enable-NetAdapter -Name $_ -Confirm:$false }\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(turn off|disable|stop).*(wifi|wi-fi|wireless).*",
        ".*(wifi|wi-fi).*(off).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"(Get-NetAdapter -Name '*Wi-Fi*','*Wireless*').Name | ForEach-Object { Disable-NetAdapter -Name $_ -Confirm:$false }\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(turn on|enable|start).*(bluetooth|bt).*",
        ".*(bluetooth|bt).*(on).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"(Get-PnpDevice -FriendlyName '*bluetooth*' -Class 'Bluetooth').FriendlyName | ForEach-Object { Enable-PnpDevice -InstanceId (Get-PnpDevice -FriendlyName $_).InstanceId -Confirm:$false }\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(turn off|disable|stop).*(bluetooth|bt).*",
        ".*(bluetooth|bt).*(off).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"(Get-PnpDevice -FriendlyName '*bluetooth*' -Class 'Bluetooth').FriendlyName | ForEach-Object { Disable-PnpDevice -InstanceId (Get-PnpDevice -FriendlyName $_).InstanceId -Confirm:$false }\"" }
    }
  ]
}
