{
  "commands": [
    {
      "type": "regex",
      "phrases": [
        ".*(save|take|capture|grab)?.*(screenshot).*",
        ".*(save|take|capture|grab).*(screen).*"
      ],
      "action": "take_screenshot",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(open|show).*(recent).*(files|documents|used).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shell:recent" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(show|open|what).*(startup).*(programs|apps|items).*"
      ],
      "action": "run_cmd",
      "params": { "command": "shell:startup" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(show|open|what).*(environment variables|env vars|path variable|system environment).*"
      ],
      "action": "run_cmd",
      "params": { "command": "set" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(system restore|restore point).*"
      ],
      "action": "run_cmd",
      "params": { "command": "rstrui" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(check|what|show).*(windows|os) (version).*"
      ],
      "action": "run_cmd",
      "params": { "command": "winver" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(check|show|run).*(directx|dxdiag).*"
      ],
      "action": "run_cmd",
      "params": { "command": "dxdiag /t dxdiag.txt && type dxdiag.txt" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(run|open|start).*(command|cmd) (as admin|administrator).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"Start-Process cmd -Verb RunAs\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what|show|tell me).*(time is it|current time|time).*"
      ],
      "action": "run_cmd",
      "params": { "command": "time /t" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what|show|tell me).*(date|today's date).*"
      ],
      "action": "run_cmd",
      "params": { "command": "date /t" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what|show|tell me).*(day is it|day of week|today's day).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"Get-Date -Format 'dddd'\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(installed|list).*(programs|apps|software|applications).*"
      ],
      "action": "run_cmd",
      "params": { "command": "wmic product get name,version" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(clear|delete).*(command history|history).*"
      ],
      "action": "run_cmd",
      "params": { "command": "doskey /listsize=0" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what is my|show|tell me).*(username|user|who am i|logged in user).*"
      ],
      "action": "run_cmd",
      "params": { "command": "whoami" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(list|show|all).*(users|user accounts).*"
      ],
      "action": "run_cmd",
      "params": { "command": "net user" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(show|get).*(wifi password|saved wifi|wi fi password).*"
      ],
      "action": "run_cmd",
      "params": { "command": "netsh wlan show profile" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(show|get|tell me|what is|what's|my).*(wifi|wi fi) password( for )?(.*)"
      ],
      "action": "get_wifi_password",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(generate|create|random).*(password|secure password).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"-join ((33..126) | Get-Random -Count 16 | ForEach-Object { [char]$_ })\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(generate|create|new|random).*(uuid|guid).*"
      ],
      "action": "run_cmd",
      "params": { "command": "powershell -Command \"[guid]::NewGuid().ToString()\"" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(who).*(created|made|built).*(you|sara).*",
        ".*(what are you|what is sara|about yourself).*"
      ],
      "action": "run_cmd",
      "params": { "command": "echo I am SARA - System Runtime Autonomous Agent. I help you control your Windows PC via Telegram." }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(help|commands|what can you do|capabilities).*"
      ],
      "action": "show_help",
      "params": {}
    }
  ]
}
