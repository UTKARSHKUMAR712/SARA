{
  "commands": [
    {
      "type": "prefix",
      "phrases": [
        "play ", "please play ", "start playing ", "play song ",
        "play music ", "could you play ", "can you play ",
        "i want to hear ", "i want to listen to ", "play the song ",
        "play me ", "play some ", "play the "
      ],
      "action": "play_music",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(pause|stop|hold on).*(song|music|playing|playback|track|it)?"
      ],
      "action": "media_command",
      "params": { "action": "spotify_pause" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(next|skip|forward).*(song|track|one|music)?"
      ],
      "action": "media_command",
      "params": { "action": "spotify_next" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(previous|go back|last|back).*(song|track|one|music)?"
      ],
      "action": "media_command",
      "params": { "action": "spotify_prev" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(play|resume|go back to).*(last|recent|previous).*(playlist).*"
      ],
      "action": "play_last_playlist",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(resume|continue|unpause|play again|start again).*(playing|music|song|playback|spotify|track)?"
      ],
      "action": "media_command",
      "params": { "action": "spotify_resume" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(toggle).*(play|pause|music|song|playback).*",
        ".*(play/pause|play or pause).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_toggle" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(shuffle|random|randomize).*(on|all|songs|music|playlist)?.*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_shuffle_on" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(shuffle|random).*(off|disable|stop|no).*",
        ".*(play in order).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_shuffle_off" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(repeat|loop|continuous).*(on|all|playlist).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_repeat_all" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(repeat|loop).*(one|current|this|single|track|song).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_repeat_one" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(repeat|loop).*(off|disable|stop|no|cancel).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_repeat_off" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(like|love|heart|favorite|fav|save).*(this|song|track|music|library).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_heart" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(unlike|unheart|remove|dislike).*(heart|favorite|liked|song|track|music).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_unheart" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what|which|tell me).*(song|track|playing|music).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_current_track" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(add to|queue).*(queue|playlist|next).*"
      ],
      "action": "media_command",
      "params": { "action": "spotify_queue" }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(volume up|increase volume|turn up|louder|raise volume|boost volume).*"
      ],
      "action": "volume_set",
      "params": { "level": 60 }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(volume down|decrease volume|turn down|quieter|lower volume|reduce volume).*"
      ],
      "action": "volume_set",
      "params": { "level": 30 }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(max|full|maximum|100).*(volume|blast).*"
      ],
      "action": "volume_set",
      "params": { "level": 100 }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(mute|silence|turn off sound|silent|no sound|disable audio).*"
      ],
      "action": "volume_mute",
      "params": { "mute": true }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(unmute|turn on sound|enable audio|sound on).*"
      ],
      "action": "volume_mute",
      "params": { "mute": false }
    },
    {
      "type": "regex",
      "phrases": [
        ".*(set|change|adjust).*(volume|vol).*(to)? (\\d+).*",
        ".*(volume|vol).*(to)? (\\d+).*"
      ],
      "action": "set_volume_level",
      "params": {}
    },
    {
      "type": "regex",
      "phrases": [
        ".*(what|check).*(volume).*"
      ],
      "action": "volume_get",
      "params": {}
    }
  ]
}
